# 复制到 data/secret.env 并填写真实值(纯 KEY=VAL, 不要带 export)。
# data/ 已 gitignore, 不会入库。可由 ~/.xianyu.env 转换:
#   sed 's/^export //' ~/.xianyu.env > data/secret.env
XIANYU_SMTP_HOST=smtp.exmail.qq.com
XIANYU_SMTP_PORT=465
XIANYU_SMTP_USER=you@example.com
XIANYU_SMTP_PASS=你的客户端专用密码
XIANYU_NOTIFY_TO=you@example.com
