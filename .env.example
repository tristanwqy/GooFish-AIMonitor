# 本地配置模板。复制到仓库根 `.env` 或 `data/secret.env` 后填值 —— 两者都已 gitignore, 不入仓库。
# 所有键带 XIANYU_ 前缀, 覆盖 config.py Settings 默认值。Settings 同时读这两个文件。
# XIANYU_DATA_DIR 默认锚定到仓库根的 data/(与启动目录无关), 一般不用改
XIANYU_MIN_DROP_PCT=5.0
XIANYU_MIN_DROP_ABS=50.0
XIANYU_HEADLESS=false
XIANYU_ACTION_DELAY_MIN=3.0
XIANYU_ACTION_DELAY_MAX=8.0

# --- LLM 二次审核(任意 OpenAI 兼容接口) ---
# 接口 base url。代码默认 https://api.openai.com/v1; 自建/内网代理填这里, 不要写进仓库。
# XIANYU_REVIEW_BASE_URL=https://api.openai.com/v1
# XIANYU_REVIEW_API_TOKEN=          # 无鉴权可留空
# XIANYU_REVIEW_MODEL=doubao-seed-2.0-pro

# --- 密钥(SMTP / 收件人), 放 data/secret.env, 不要写进仓库 ---
# XIANYU_SMTP_HOST=smtp.example.com
# XIANYU_SMTP_PORT=465
# XIANYU_SMTP_USER=you@example.com
# XIANYU_SMTP_PASS=********
# XIANYU_NOTIFY_TO=you@example.com
